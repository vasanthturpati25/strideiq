DEBUG=True
SECRET_KEY=your-secret-key-change-in-production
ALLOWED_HOSTS=localhost,127.0.0.1

# CORS — add frontend URL here in production
CORS_ALLOWED_ORIGINS=http://localhost:3000

# SQLite DB filename (relative to backend/)
DATABASE_NAME=strideiq.db

# Media / upload folder (relative to backend/)
UPLOAD_FOLDER=media/uploads
MAX_CONTENT_LENGTH_MB=100

# AWS S3 (optional — local media used if not set)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
S3_BUCKET_NAME=
